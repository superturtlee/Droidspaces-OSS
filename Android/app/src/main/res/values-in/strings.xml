    <string name="privileged_mode_description">Konfigurasikan pelonggaran keamanan terperinci untuk virtualisasi bersarang atau akses perangkat keras tingkat lanjut.</string>
    <string name="privileged_nomask_desc">Nonaktifkan pembatasan akses untuk mengizinkan akses tulis ke /proc dan /sys. Catatan: /sys tetap hanya dapat dibaca kecuali jika Akses Perangkat Keras juga diaktifkan.</string>
    <string name="privileged_nocaps_desc">Jangan lepaskan kemampuan Linux (hak akses root penuh).</string>
    <string name="privileged_noseccomp_desc">Nonaktifkan penyaringan panggilan sistem Seccomp. Hal ini mengaktifkan fitur-fitur kernel tingkat lanjut seperti ruang nama pengguna tanpa hak istimewa, yang sangat diperlukan untuk sandboxing bersarang (Bubblewrap, Flatpak), serta memungkinkan pemuatan modul kernel yang tidak termasuk dalam pohon sumber.</string>
    <string name="privileged_shared_desc">Aktifkan penyebaran mount MS_SHARED ke host.</string>
    <string name="privileged_unfiltered_desc">Melewati penyaringan perangkat. Semua node host /dev menjadi terlihat.</string>
    <string name="privileged_full_desc">Aktifkan semua bendera hak istimewa sekaligus.</string>
    <string name="privileged_warning_title">WILAYAH BERBAHAYA</string>
    <string name="privileged_disclaimer">Dengan mengaktifkan opsi-opsi ini, Anda membahayakan keamanan perangkat Anda. Kami TIDAK bertanggung jawab atas kehilangan data, perangkat yang rusak total, atau bug yang aneh. JANGAN laporkan masalah yang terjadi saat menggunakan mode-mode ini.</string>
    <string name="privileged_confirm_instruction">Ketik “SAYA TIDAK AKAN MELAPORKAN BUG APA PUN” persis seperti ini dengan huruf besar untuk mengonfirmasi:</string>
    <string name="i_understand_caps">SAYA TIDAK AKAN MELAPORKAN BUG APAPUN</string>
    <string name="reboot_recommended">Disarankan untuk me-reboot sistem agar aturan SELinux diterapkan dan daemon berjalan saat booting.</string>
    <string name="mask_service">Layanan mask</string>
    <string name="no_masked_services">Tidak ada layanan masked</string>
    <string name="bind_mounts">Mount Bind</string>
    <string name="welcome_tagline">Container Linux. Native. Tanpa overhead.</string>
    <string name="feat_containers_title">Container Linux nyata</string>
    <string name="feat_containers_desc">Teknologi namespace kernel Linux yang sama dengan LXC, Podman, dan Docker. Tanpa emulasi, tanpa chroot.</string>
    <string name="feat_overhead_title">Nol overhead</string>
    <string name="feat_overhead_desc">Berkomunikasi langsung dengan kernel Linux host. Tanpa hypervisor, tanpa lapisan mesin virtual.</string>
    <string name="feat_unkillable_title">Tidak dapat dihentikan paksa</string>
    <string name="feat_unkillable_desc">Mendukung integrasi init.rc native dan daemon userspace 2 lapis. Sepenuhnya tidak dapat dihentikan paksa.</string>
    <string name="feat_init_title">systemd / OpenWrt procd / OpenRC sebagai PID 1</string>
    <string name="feat_init_desc">Dukungan sistem init penuh. Manajemen layanan nyata, bukan lingkungan simulasi.</string>
    <string name="feat_isolation_title">Isolasi lengkap</string>
    <string name="feat_isolation_desc">Pohon PID, tabel mount, nama host, IPC, dan hierarki cgroup privat per container.</string>
    <string name="feat_hardware_title">Akses hardware/GPU penuh</string>
    <string name="feat_hardware_desc">Paparkan hardware host (GPU, sensor, USB, perangkat blok) langsung ke container Anda.</string>
    <string name="feat_privileged_title">Container privileged penuh</string>
    <string name="feat_privileged_desc">Longgarkan hambatan keamanan dengan mode privileged untuk pengguna tingkat lanjut.</string>
    <string name="feat_autoboot_title">Boot otomatis saat dinyalakan</string>
    <string name="feat_autoboot_desc">Mulai container secara otomatis saat boot, bahkan jika layar terkunci dan data terenkripsi.</string>
