    <string name="welcome_tagline">Contenitori Linux. Nativi. Nessun overhead.</string>
    <string name="feat_containers_title">Contenitori Linux reali</string>
    <string name="feat_containers_desc">Stessa tecnologia di namespace del kernel di LXC, Podman e Docker. Nessuna emulazione, nessun chroot.</string>
    <string name="feat_overhead_title">Zero overhead</string>
    <string name="feat_overhead_desc">Comunica direttamente con il kernel Linux host. Nessun hypervisor, nessun livello di macchina virtuale.</string>
    <string name="feat_unkillable_title">Indistruttibile per progettazione</string>
    <string name="feat_unkillable_desc">Supporta l\'integrazione nativa init.rc e daemon userspace a 2 livelli. Completamente indistruttibile.</string>
    <string name="feat_init_title">systemd / OpenRC come PID 1</string>
    <string name="feat_init_desc">Supporto completo del sistema init. Gestione dei servizi reale, non un ambiente simulato.</string>
    <string name="feat_isolation_title">Isolamento completo</string>
    <string name="feat_isolation_desc">Albero PID privato, tabella di montaggio, nome host, IPC e gerarchia cgroup per contenitore.</string>
    <string name="feat_hardware_title">Accesso completo hardware/GPU</string>
    <string name="feat_hardware_desc">Esporre l\'hardware host (GPU, sensori, USB, dispositivi a blocchi) direttamente ai contenitori.</string>
    <string name="feat_privileged_title">Contenitori con privilegi completi</string>
    <string name="feat_privileged_desc">Abbassa le barriere di sicurezza con la modalità privilegiata per utenti avanzati.</string>
    <string name="feat_autoboot_title">Avvio automatico all\'accensione</string>
    <string name="feat_autoboot_desc">Avvia automaticamente i contenitori all\'avvio, anche se lo schermo è bloccato e i dati sono crittografati.</string>
